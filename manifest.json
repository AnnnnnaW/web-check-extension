{
  "manifest_version": 3,
  "name": "公開前チェッカー",
  "version": "1.0.0",
  "description": "Web制作の公開前チェックをワンクリックで。ALT属性・noindex・リンク切れ・GA4タグなどを一括確認。",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "公開前チェッカー"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"]
    }
  ]
}
