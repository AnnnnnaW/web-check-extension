{
  "manifest_version": 3,
  "name": "公開前チェッカー",
  "version": "1.0.1",
  "description": "Web制作の公開前チェックをワンクリックで。ALT属性・noindex・見出し構造・GA4タグなどを一括確認。",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "公開前チェッカー"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
